VERSION 5.8 ;
DIVIDERCHAR "/" ;
BUSBITCHARS "[]" ;
DESIGN mask_solve_oddcycle ;
UNITS DISTANCE MICRONS 1000 ;
DIEAREA ( 0 0 ) ( 20000 20000 ) ;
COMPONENTS 0 ;
END COMPONENTS
SPECIALNETS 0 ;
END SPECIALNETS
NETS 3 ;
- a
  + ROUTED met1 ( 1000 1000 ) ( 1100 1000 )
 ;
- b
  + ROUTED met1 ( 1000 1260 ) ( 1100 1260 )
 ;
- c
  + ROUTED met1 ( 1260 1130 ) ( 1360 1130 )
 ;
END NETS
END DESIGN
