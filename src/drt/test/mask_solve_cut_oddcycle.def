VERSION 5.8 ;
DIVIDERCHAR "/" ;
BUSBITCHARS "[]" ;
DESIGN mask_solve_cut_oddcycle ;
UNITS DISTANCE MICRONS 1000 ;
DIEAREA ( 0 0 ) ( 20000 20000 ) ;
COMPONENTS 0 ;
END COMPONENTS
SPECIALNETS 0 ;
END SPECIALNETS
NETS 3 ;
- a
  + ROUTED met1 ( 1000 1000 ) M1M2_PR
    NEW met2 ( 1000 1000 ) ( 1000 5000 )
 ;
- b
  + ROUTED met1 ( 1300 1000 ) M1M2_PR
    NEW met2 ( 1300 1000 ) ( 1300 5000 )
 ;
- c
  + ROUTED met1 ( 1150 1260 ) M1M2_PR
    NEW met2 ( 1150 1260 ) ( 1150 5000 )
 ;
END NETS
END DESIGN
