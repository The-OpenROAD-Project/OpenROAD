VERSION 5.8 ;
DIVIDERCHAR "/" ;
BUSBITCHARS "[]" ;
DESIGN mask_solve_cut ;
UNITS DISTANCE MICRONS 1000 ;
DIEAREA ( 0 0 ) ( 20000 20000 ) ;
COMPONENTS 0 ;
END COMPONENTS
SPECIALNETS 0 ;
END SPECIALNETS
NETS 3 ;
- n0
  + ROUTED met1 ( 1000 2000 ) M1M2_PR
    NEW met2 ( 1000 2000 ) ( 1000 3000 )
 ;
- n1
  + ROUTED met1 ( 1300 2000 ) M1M2_PR
    NEW met2 ( 1300 2000 ) ( 1300 3000 )
 ;
- n2
  + ROUTED met1 ( 1600 2000 ) M1M2_PR
    NEW met2 ( 1600 2000 ) ( 1600 3000 )
 ;
END NETS
END DESIGN
