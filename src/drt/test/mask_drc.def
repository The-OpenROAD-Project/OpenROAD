VERSION 5.8 ;
DIVIDERCHAR "/" ;
BUSBITCHARS "[]" ;
DESIGN mask_drc ;
UNITS DISTANCE MICRONS 1000 ;
DIEAREA ( 0 0 ) ( 20000 20000 ) ;
COMPONENTS 0 ;
END COMPONENTS
SPECIALNETS 0 ;
END SPECIALNETS
NETS 4 ;
- na
  + ROUTED met1 ( 1000 2000 ) MASK 2 ( 4000 2000 )
 ;
- nb
  + ROUTED met1 ( 1000 2240 ) MASK 2 ( 4000 2240 )
 ;
- nc
  + ROUTED met1 ( 10000 2000 ) MASK 1 ( 13000 2000 )
 ;
- nd
  + ROUTED met1 ( 10000 2240 ) MASK 2 ( 13000 2240 )
 ;
END NETS
END DESIGN
