VERSION 5.8 ;
DIVIDERCHAR "/" ;
BUSBITCHARS "[]" ;
DESIGN mask_solve_ok ;
UNITS DISTANCE MICRONS 1000 ;
DIEAREA ( 0 0 ) ( 20000 20000 ) ;
COMPONENTS 0 ;
END COMPONENTS
SPECIALNETS 0 ;
END SPECIALNETS
NETS 3 ;
- n0
  + ROUTED met1 ( 1000 2000 ) ( 4000 2000 )
 ;
- n1
  + ROUTED met1 ( 1000 2200 ) ( 4000 2200 )
 ;
- n2
  + ROUTED met1 ( 1000 2400 ) ( 4000 2400 )
 ;
END NETS
END DESIGN
