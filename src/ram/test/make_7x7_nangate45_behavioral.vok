module RAM7x7 (
  clk,
  D,
  Q,
  addr_rw,
  we
);
  input clk;
  input [6:0] D;
  output reg [6:0] Q;
  input [2:0] addr_rw;
  input [0:0] we;

  // memory array declaration
  reg [6:0] mem[0:6];

  // write logic
  integer i;
  always @(posedge clk) begin
    for (i = 0; i < 1; i = i + 1) begin
      if (we[i]) begin
        mem[addr_rw][i*7 +:7] <= D[i*7 +:7];
      end
    end
  end

  // read logic
  always @(*) begin
    Q = mem[addr_rw];
  end

endmodule
