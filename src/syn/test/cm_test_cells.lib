      function : "A&(B|C)";
      timing () {
        related_pin : "A B C";
        cell_rise (scalar) { values ("1.0"); }
        cell_fall (scalar) { values ("1.0"); }
        rise_transition (scalar) { values ("0.01"); }
        fall_transition (scalar) { values ("0.01"); }
      }
    }
  }

  cell(OA21) {
    area : 5;
    pin(A) { direction : input; capacitance : 0.001; }
    pin(B) { direction : input; capacitance : 0.001; }
    pin(C) { direction : input; capacitance : 0.001; }
    pin(Y) {
      direction : output;
      function : "A|(B&C)";
      timing () {
        related_pin : "A B C";
        cell_rise (scalar) { values ("1.0"); }
        cell_fall (scalar) { values ("1.0"); }
        rise_transition (scalar) { values ("0.01"); }
        fall_transition (scalar) { values ("0.01"); }
      }
    }
  }

  cell(TIELO) {
    area : 1;
    pin(Y) { direction : output; function : "0"; }
  }

  cell(TIEHI) {
    area : 1;
    pin(Y) { direction : output; function : "1"; }
  }
}
