library(cm_test) {
  delay_model : table_lookup;
  time_unit : "1ns";
  voltage_unit : "1V";
  current_unit : "1mA";
  capacitive_load_unit(1, pf);

  cell(INV) {
    area : 1;
    pin(A) { direction : input; capacitance : 0.001; }
    pin(Y) { direction : output; function : "!A"; }
  }

  cell(BUF) {
    area : 2;
    pin(A) { direction : input; capacitance : 0.001; }
    pin(Y) { direction : output; function : "A"; }
  }

  cell(AND2) {
    area : 3;
    pin(A) { direction : input; capacitance : 0.001; }
    pin(B) { direction : input; capacitance : 0.001; }
    pin(Y) { direction : output; function : "A&B"; }
  }

  cell(OR2) {
    area : 3;
    pin(A) { direction : input; capacitance : 0.001; }
    pin(B) { direction : input; capacitance : 0.001; }
    pin(Y) { direction : output; function : "A|B"; }
  }

  cell(NAND2) {
    area : 2;
    pin(A) { direction : input; capacitance : 0.001; }
    pin(B) { direction : input; capacitance : 0.001; }
    pin(Y) { direction : output; function : "!(A&B)"; }
  }

  cell(NOR2) {
    area : 2;
    pin(A) { direction : input; capacitance : 0.001; }
    pin(B) { direction : input; capacitance : 0.001; }
    pin(Y) { direction : output; function : "!(A|B)"; }
  }

  cell(ANDNOT2) {
    area : 3;
    pin(A) { direction : input; capacitance : 0.001; }
    pin(B) { direction : input; capacitance : 0.001; }
    pin(Y) { direction : output; function : "A&!B"; }
  }

  cell(ORNOT2) {
    area : 3;
    pin(A) { direction : input; capacitance : 0.001; }
    pin(B) { direction : input; capacitance : 0.001; }
    pin(Y) { direction : output; function : "A|!B"; }
  }

  cell(XOR2) {
    area : 5;
    pin(A) { direction : input; capacitance : 0.001; }
    pin(B) { direction : input; capacitance : 0.001; }
    pin(Y) { direction : output; function : "(A&!B)|(!A&B)"; }
  }

  cell(XNOR2) {
    area : 5;
    pin(A) { direction : input; capacitance : 0.001; }
    pin(B) { direction : input; capacitance : 0.001; }
    pin(Y) { direction : output; function : "(A&B)|(!A&!B)"; }
  }

  cell(MUX2) {
    area : 7;
    pin(A) { direction : input; capacitance : 0.001; }
    pin(B) { direction : input; capacitance : 0.001; }
    pin(S) { direction : input; capacitance : 0.001; }
    pin(Y) { direction : output; function : "(A&!S)|(B&S)"; }
  }

  cell(AOI21) {
    area : 4;
    pin(A) { direction : input; capacitance : 0.001; }
    pin(B) { direction : input; capacitance : 0.001; }
    pin(C) { direction : input; capacitance : 0.001; }
    pin(Y) { direction : output; function : "!(A&(B|C))"; }
  }

  cell(OAI21) {
    area : 4;
    pin(A) { direction : input; capacitance : 0.001; }
    pin(B) { direction : input; capacitance : 0.001; }
    pin(C) { direction : input; capacitance : 0.001; }
    pin(Y) { direction : output; function : "!(A|(B&C))"; }
  }

  cell(AO21) {
    area : 5;
    pin(A) { direction : input; capacitance : 0.001; }
    pin(B) { direction : input; capacitance : 0.001; }
    pin(C) { direction : input; capacitance : 0.001; }
    pin(Y) { direction : output; function : "A&(B|C)"; }
  }

  cell(OA21) {
    area : 5;
    pin(A) { direction : input; capacitance : 0.001; }
    pin(B) { direction : input; capacitance : 0.001; }
    pin(C) { direction : input; capacitance : 0.001; }
    pin(Y) { direction : output; function : "A|(B&C)"; }
  }

  cell(TIELO) {
    area : 1;
    pin(Y) { direction : output; function : "0"; }
  }

  cell(TIEHI) {
    area : 1;
    pin(Y) { direction : output; function : "1"; }
  }
}
