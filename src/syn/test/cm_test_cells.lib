        cell_rise (scalar) { values ("1.0"); }
        cell_fall (scalar) { values ("1.0"); }
        rise_transition (scalar) { values ("0.01"); }
        fall_transition (scalar) { values ("0.01"); }
      }
    }
  }

  cell(NAND2) {
    area : 2;
    pin(A) { direction : input; capacitance : 0.001; }
    pin(B) { direction : input; capacitance : 0.001; }
    pin(Y) {
