library(cm_test) {
  delay_model : table_lookup;
  time_unit : "1ns";
  voltage_unit : "1V";
  current_unit : "1mA";
  capacitive_load_unit(1, pf);

  nom_process : 1.0;
  nom_temperature : 25.0;
  nom_voltage : 1.0;
  operating_conditions(typ) {
    process : 1.0;
    temperature : 25.0;
    voltage : 1.0;
    tree_type : balanced_tree;
  }
  default_operating_conditions : typ;

  cell(INV) {
    area : 1;
    pin(A) { direction : input; capacitance : 0.001; }
    pin(Y) {
      direction : output;
      function : "!A";
      timing () {
        related_pin : "A";
        cell_rise (scalar) { values ("1.0"); }
        cell_fall (scalar) { values ("1.0"); }
        rise_transition (scalar) { values ("0.01"); }
        fall_transition (scalar) { values ("0.01"); }
      }
    }
  }

  cell(BUF) {
    area : 2;
    pin(A) { direction : input; capacitance : 0.001; }
    pin(Y) {
      direction : output;
      function : "A";
      timing () {
        related_pin : "A";
        cell_rise (scalar) { values ("1.0"); }
        cell_fall (scalar) { values ("1.0"); }
        rise_transition (scalar) { values ("0.01"); }
        fall_transition (scalar) { values ("0.01"); }
      }
    }
  }

  cell(AND2) {
    area : 3;
    pin(A) { direction : input; capacitance : 0.001; }
    pin(B) { direction : input; capacitance : 0.001; }
    pin(Y) {
      direction : output;
      function : "A&B";
      timing () {
        related_pin : "A B";
        cell_rise (scalar) { values ("1.0"); }
        cell_fall (scalar) { values ("1.0"); }
        rise_transition (scalar) { values ("0.01"); }
        fall_transition (scalar) { values ("0.01"); }
      }
    }
  }

  cell(OR2) {
    area : 3;
    pin(A) { direction : input; capacitance : 0.001; }
    pin(B) { direction : input; capacitance : 0.001; }
    pin(Y) {
      direction : output;
