module reg1 (clk);
 input clk;

 wire r1q;
 wire u1z;
 wire u2z;
 wire u3z;
 wire u4z;
 wire u5z;
 wire net1;
 wire net2;
 wire net3;
 wire net4;
 wire net5;
 wire net6;

 DFF_X1 r1 (.CK(clk),
    .Q(r1q));
 DFF_X1 r10 (.D(net1));
 DFF_X1 r11 (.D(net1));
 DFF_X1 r12 (.D(net1));
 DFF_X1 r2 (.D(u5z),
    .CK(clk));
 DFF_X1 r3 (.D(r1q),
    .CK(clk));
 DFF_X1 r4 (.D(r1q),
    .CK(clk));
 DFF_X1 r5 (.D(r1q),
    .CK(clk));
 DFF_X1 r6 (.D(r1q),
    .CK(clk));
 DFF_X1 r7 (.D(r1q),
    .CK(clk));
 DFF_X1 r8 (.D(net1));
 DFF_X1 r9 (.D(net1));
 BUF_X1 u1 (.A(r1q),
    .Z(u1z));
 BUF_X1 u2 (.A(u1z),
    .Z(u2z));
 BUF_X1 u3 (.A(u2z),
    .Z(u3z));
 BUF_X1 u4 (.A(u3z),
    .Z(u4z));
 BUF_X1 u5 (.A(u4z),
    .Z(u5z));
 BUF_X1 split1 (.A(net2),
    .Z(net1));
 BUF_X1 rebuffer2 (.A(net3),
    .Z(net2));
 BUF_X1 rebuffer3 (.A(net4),
    .Z(net3));
 BUF_X1 rebuffer4 (.A(net5),
    .Z(net4));
 BUF_X1 rebuffer5 (.A(net6),
    .Z(net5));
 BUF_X1 rebuffer6 (.A(r1q),
    .Z(net6));
endmodule
