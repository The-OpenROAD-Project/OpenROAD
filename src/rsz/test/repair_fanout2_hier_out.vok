    .Z(net14));
 BUF_X1 fanout7 (.A(net20),
    .Z(net17));
 BUF_X1 fanout8 (.A(net0),
    .Z(net20));
 hi_fanout_child h0 (.net0_18(net17),
    .net0_15(net14),
    .net0_12(net11),
    .net0_9(net8),
    .net0_5(net4),
    .net0_2(net1),
    .net0(net20),
    .clk1(clk1));
 hi_fanout_child_h1 h1 (.net0_19(net17),
    .net0_16(net14),
    .net0_13(net11),
    .net0_10(net8),
    .net0_6(net4),
    .net0_3(net1),
    .net0(net20),
    .clk1(clk1));
endmodule
