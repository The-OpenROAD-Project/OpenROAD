module hi_fanout (clk1,
    in);
 input clk1;
 input in;

 wire net18;
 wire net15;
 wire net12;
 wire net8;
 wire net5;
 wire net1;
 wire net0;

 DFF_X1 drvr (.D(in),
    .CK(clk1),
    .Q(net0));
 BUF_X1 fanout1 (.A(net8),
    .Z(net1));
 BUF_X1 fanout3 (.A(net8),
    .Z(net5));
 BUF_X1 fanout4 (.A(net0),
    .Z(net8));
 BUF_X1 fanout6 (.A(net18),
    .Z(net12));
 BUF_X1 fanout7 (.A(net18),
    .Z(net15));
 BUF_X1 fanout8 (.A(net0),
    .Z(net18));
 hi_fanout_child h0 (.net0_16(net15),
    .net0_13(net12),
    .net0_9(net8),
    .net0_6(net5),
    .net0_2(net1),
    .net0(net18),
    .clk1(clk1));
 hi_fanout_child_h1 h1 (.net0_19(net18),
    .net0_17(net15),
    .net0_14(net12),
    .net0_10(net8),
    .net0_7(net5),
    .net0_3(net1),
    .net0(net0),
    .clk1(clk1));
endmodule
