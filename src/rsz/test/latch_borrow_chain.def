VERSION 5.8 ;
DIVIDERCHAR "/" ;
BUSBITCHARS "[]" ;
DESIGN latch_borrow_chain ;
UNITS DISTANCE MICRONS 2000 ;

DIEAREA ( 0 0 ) ( 240000 240000 ) ;

COMPONENTS 13 ;
- deep_buf0 BUF_X1 + PLACED ( 20000 120000 ) N ;
- deep_buf1 BUF_X1 + PLACED ( 50000 120000 ) N ;
- deep_latch DLL_X1 + PLACED ( 62500 158990 ) N ;
- mid_buf0 BUF_X1 + PLACED ( 73000 120000 ) N ;
- mid_buf1 BUF_X1 + PLACED ( 82000 120000 ) N ;
- enable_latch DLL_X1 + PLACED ( 89540 158990 ) N ;
- inferred_gate AND2_X1 + PLACED ( 88400 89470 ) N ;
- sibling_branch CLKBUF_X3 + PLACED ( 91580 89470 ) N ;
- sibling_ff0 DFF_X1 + PLACED ( 139840 89510 ) N ;
- gated_ff0 DFF_X1 + PLACED ( 159600 158985 ) N ;
- gated_ff1 DFF_X1 + PLACED ( 167580 158985 ) N ;
- gated_ff2 DFF_X1 + PLACED ( 159600 167045 ) N ;
- gated_ff3 DFF_X1 + PLACED ( 167580 167045 ) N ;
END COMPONENTS

PINS 2 ;
- clk + NET clk + DIRECTION INPUT + USE SIGNAL
  + LAYER metal6 ( -140 0 ) ( 140 280 ) + FIXED ( 120000 240000 ) S ;
- en_in + NET en_in + DIRECTION INPUT + USE SIGNAL
  + LAYER metal6 ( -140 0 ) ( 140 280 ) + FIXED ( 0 120000 ) W ;
END PINS

NETS 10 ;
- clk
  ( PIN clk )
  ( enable_latch GN )
  ( deep_latch GN )
  ( inferred_gate A1 )
  ( sibling_branch A )
  + USE SIGNAL ;
- en_in
  ( PIN en_in )
  ( deep_buf0 A )
  + USE SIGNAL ;
- deep_mid0
  ( deep_buf0 Z )
  ( deep_buf1 A )
  + USE SIGNAL ;
- deep_mid1
  ( deep_buf1 Z )
  ( deep_latch D )
  + USE SIGNAL ;
- deep_lat
  ( deep_latch Q )
  ( mid_buf0 A )
  + USE SIGNAL ;
- en_mid0
  ( mid_buf0 Z )
  ( mid_buf1 A )
  + USE SIGNAL ;
- en_mid1
  ( mid_buf1 Z )
  ( enable_latch D )
  + USE SIGNAL ;
- en_lat
  ( enable_latch Q )
  ( inferred_gate A2 )
  ( sibling_ff0 D )
  ( gated_ff0 D )
  ( gated_ff1 D )
  ( gated_ff2 D )
  ( gated_ff3 D )
  + USE SIGNAL ;
- sibling_clk
  ( sibling_branch Z )
  ( sibling_ff0 CK )
  + USE SIGNAL ;
- gated_clk
  ( inferred_gate ZN )
  ( gated_ff0 CK )
  ( gated_ff1 CK )
  ( gated_ff2 CK )
  ( gated_ff3 CK )
  + USE SIGNAL ;
END NETS

END DESIGN
