VERSION 5.8 ;
DIVIDERCHAR "/" ;
BUSBITCHARS "[]" ;
DESIGN top ;
UNITS DISTANCE MICRONS 1000 ;
DIEAREA ( 0 0 ) ( 100000 100000 ) ;
ROW ROW_0 FreePDK45_38x28_10R_NP_162NW_34O 40090 40600 N DO 104 BY 1 STEP 190 0 ;
ROW ROW_1 FreePDK45_38x28_10R_NP_162NW_34O 40090 42000 FS DO 104 BY 1 STEP 190 0 ;
ROW ROW_2 FreePDK45_38x28_10R_NP_162NW_34O 40090 43400 N DO 104 BY 1 STEP 190 0 ;
ROW ROW_3 FreePDK45_38x28_10R_NP_162NW_34O 40090 44800 FS DO 104 BY 1 STEP 190 0 ;
ROW ROW_4 FreePDK45_38x28_10R_NP_162NW_34O 40090 46200 N DO 104 BY 1 STEP 190 0 ;
ROW ROW_5 FreePDK45_38x28_10R_NP_162NW_34O 40090 47600 FS DO 104 BY 1 STEP 190 0 ;
COMPONENTS 5 ;
    - c1 BUF_X1 + PLACED ( 40090 40600 ) N ;
    - dbuf BUF_X1 + PLACED ( 40280 40600 ) N ;
    - r1 DFF_X1 + PLACED ( 40090 42000 ) FS ;
    - r2 DFF_X1 + PLACED ( 40280 42000 ) FS ;
    - i1 BUF_X1 + PLACED ( 40470 40600 ) N ;
END COMPONENTS
PINS 3 ;
    - clk1 + NET clk1 + DIRECTION INPUT + USE SIGNAL
      + PORT
        + LAYER metal2 ( 0 0 ) ( 0 0 )
        + FIXED ( 40000 0 ) N ;
    - clk2 + NET clk2 + DIRECTION INPUT + USE SIGNAL
      + PORT
        + LAYER metal2 ( 0 0 ) ( 0 0 )
        + FIXED ( 41000 0 ) N ;
    - out + NET out + DIRECTION OUTPUT + USE SIGNAL
      + PORT
        + LAYER metal2 ( 0 0 ) ( 0 0 )
        + FIXED ( 0 0 ) N ;
END PINS
NETS 7 ;
    - clk1 ( PIN clk1 ) ( i1 A ) ( dbuf A ) + USE SIGNAL ;
    - i1z ( i1 Z ) ( r1 CK ) + USE SIGNAL ;
    - clk2 ( PIN clk2 ) ( c1 A ) + USE SIGNAL ;
    - c1z ( c1 Z ) ( r2 CK ) + USE SIGNAL ;
    - dz ( dbuf Z ) ( r2 D ) + USE SIGNAL ;
    - r1q ( r1 Q ) ( r1 D ) + USE SIGNAL ;
    - out ( PIN out ) ( r2 Q ) + USE SIGNAL ;
END NETS
END DESIGN
