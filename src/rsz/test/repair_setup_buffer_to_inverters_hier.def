# Hierarchical BufferToInvertersMove fixture: same geometry as the flat variant,
# but the BUF_X4 lives inside submod m1, so its iterms carry modnets after
# link_design -hier. The instance name in DEF must match the post-link flat
# name (m1/u1).
VERSION 5.8 ;
DIVIDERCHAR "/" ;
BUSBITCHARS "[]" ;
DESIGN reg1 ;
UNITS DISTANCE MICRONS 1000 ;
DIEAREA ( 0 0 ) ( 100000 3000000 ) ;

COMPONENTS 3 ;
- r1 DFF_X1 + PLACED   ( 50000 2900000 ) N ;
- m1/u1 BUF_X4 + PLACED   ( 50000 2850000 ) N ;
- r2 DFF_X1 + PLACED   ( 50000  100000 ) N ;
END COMPONENTS

PINS 1 ;
    - clk + NET clk + DIRECTION INPUT + USE SIGNAL + FIXED ( 10000 3333 ) N + LAYER metal2 ( 0 0 ) ( 0 0 ) ;
END PINS

SPECIALNETS 2 ;
- VSS  ( * VSS )
  + USE GROUND ;
- VDD  ( * VDD )
  + USE POWER ;
END SPECIALNETS

END DESIGN
