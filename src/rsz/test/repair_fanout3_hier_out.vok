 DFF_X1 drvr (.D(in),
    .CK(clk1),
    .Q(net11));
 BUF_X1 fanout1 (.A(net4),
    .Z(net1));
 BUF_X1 fanout2 (.A(net11),
    .Z(net4));
 BUF_X1 fanout4 (.A(net11),
    .Z(net8));
 BUF_X1 fanout5 (.A(net12),
    .Z(a));
 BUF_X1 fanout6 (.A(net11),
    .Z(net12));
 BUF_X1 fanout7 (.A(net18),
    .Z(net15));
 BUF_X1 fanout8 (.A(net11),
    .Z(net18));
 hi_fanout_child hi_fanout_inst1 (.net11_16(net15),
    .net11_13(net12),
    .net11(a),
    .a_9(net8),
    .a_5(net4),
    .a_2(net1),
    .a(net18),
    .clk1(clk1));
 hi_fanout_child_hi_fanout_inst2 hi_fanout_inst2 (.net11_17(net15),
    .net11_14(net12),
    .net11(a),
    .a_10(net8),
    .a_6(net4),
    .a_3(net1),
    .a(net18),
    .clk1(clk1));
endmodule
