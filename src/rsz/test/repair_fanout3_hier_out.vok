    .Z(net14));
 BUF_X1 fanout8 (.A(net11),
    .Z(net17));
 hi_fanout_child hi_fanout_inst1 (.net11_15(net14),
    .net11_13(net12),
    .net11(a),
    .a_9(net8),
    .a_6(net5),
    .a_2(net1),
    .a(net17),
    .clk1(clk1));
