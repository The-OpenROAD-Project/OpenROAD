 wire net20;

 DFF_X1 drvr (.D(in),
    .CK(clk1),
    .Q(net10));
 BUF_X1 fanout1 (.A(net20),
    .Z(net1));
 BUF_X1 fanout2 (.A(net20),
    .Z(net4));
 BUF_X1 fanout3 (.A(net20),
    .Z(net7));
 BUF_X1 fanout4 (.A(net20),
    .Z(a));
