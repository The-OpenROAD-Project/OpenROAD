    .Z(net17));
 BUF_X1 fanout8 (.A(net20),
    .Z(net19));
 BUF_X1 fanout9 (.A(net10),
    .Z(net20));
 hi_fanout_child hi_fanout_inst1 (.net10_15(net14),
    .net10_12(net11),
    .net10(a),
    .a_8(net7),
    .a_5(net4),
    .a_2(net1),
    .a(net17),
    .clk1(clk1));
 hi_fanout_child_hi_fanout_inst2 hi_fanout_inst2 (.net10_18(net17),
    .net10_16(net14),
    .net10_13(net11),
    .net10(a),
    .a_9(net7),
    .a_6(net4),
    .a_3(net1),
    .a(net19),
    .clk1(clk1));
endmodule
