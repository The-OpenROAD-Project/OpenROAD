VERSION 5.8 ;
DIVIDERCHAR "/" ;
BUSBITCHARS "[]" ;
DESIGN bloat_pin ;
UNITS DISTANCE MICRONS 2000 ;
DIEAREA ( 0 0 ) ( 20000 20000 ) ;
PINS 1 ;
    - sig_in + NET sig_in + DIRECTION INPUT
      + PLACED ( 0 5000 ) N
      + LAYER metal1 ( -140 -70 ) ( 0 70 ) ;
END PINS
SPECIALNETS 1 ;
    - VDD ( * VDD ) + USE POWER
      + ROUTED metal1 140 + SHAPE FOLLOWPIN ( 2000 5000 ) ( 18000 5000 ) ;
END SPECIALNETS
END DESIGN
