VERSION 5.8 ;
DIVIDERCHAR "/" ;
BUSBITCHARS "[]" ;
DESIGN multi_sink ;
UNITS DISTANCE MICRONS 2000 ;
DIEAREA ( 0 0 ) ( 24000 8400 ) ;
ROW ROW_0 FreePDK45_38x28_10R_NP_162NW_34O 0 0 N DO 63 BY 1 STEP 380 0 ;
ROW ROW_1 FreePDK45_38x28_10R_NP_162NW_34O 0 2800 FS DO 63 BY 1 STEP 380 0 ;
ROW ROW_2 FreePDK45_38x28_10R_NP_162NW_34O 0 5600 N DO 63 BY 1 STEP 380 0 ;
TRACKS X 190 DO 63 STEP 380 LAYER metal1 ;
TRACKS Y 140 DO 30 STEP 280 LAYER metal1 ;
TRACKS X 190 DO 63 STEP 380 LAYER metal2 ;
TRACKS Y 140 DO 30 STEP 280 LAYER metal2 ;
TRACKS X 190 DO 63 STEP 380 LAYER metal3 ;
TRACKS Y 140 DO 30 STEP 280 LAYER metal3 ;
COMPONENTS 2 ;
    - h1/gclk_inst CLKGATE_X1 + PLACED ( 760 2800 ) FS ;
    - h1/ff0\/name DFF_X1 + PLACED ( 6460 2800 ) FS ;
END COMPONENTS
PINS 1 ;
    - clk + NET clk + DIRECTION INPUT + USE SIGNAL
      + PORT
        + LAYER metal2 ( -70 -70 ) ( 70 70 )
        + PLACED ( 190 2940 ) N ;
END PINS
NETS 2 ;
    - clk ( PIN clk ) ( h1/gclk_inst CK ) + USE SIGNAL ;
    - h1/gclk ( h1/gclk_inst GCK ) ( h1/ff0\/name CK ) + USE SIGNAL ;
END NETS
END DESIGN
