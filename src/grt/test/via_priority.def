VERSION 5.8 ;
DIVIDERCHAR "/" ;
BUSBITCHARS "[]" ;
DESIGN via_priority ;
UNITS DISTANCE MICRONS 1000 ;
DIEAREA ( 0 0 ) ( 10000 10000 ) ;
TRACKS X 100 DO 49 STEP 200 LAYER metal1 ;
TRACKS Y 100 DO 49 STEP 200 LAYER metal1 ;
TRACKS X 100 DO 49 STEP 200 LAYER metal2 ;
TRACKS Y 100 DO 49 STEP 200 LAYER metal2 ;
COMPONENTS 0 ;
END COMPONENTS
PINS 2 ;
  - I1 + NET n1 + DIRECTION INPUT + USE SIGNAL
    + LAYER metal1 ( -50 -50 ) ( 50 50 ) + PLACED ( 1100 1100 ) N ;
  - O1 + NET n1 + DIRECTION OUTPUT + USE SIGNAL
    + LAYER metal2 ( -50 -50 ) ( 50 50 ) + PLACED ( 5100 5100 ) N ;
END PINS
NETS 1 ;
  - n1 ( PIN I1 ) ( PIN O1 ) ;
END NETS
END DESIGN
